{
  "expo": {
    "name": "DüşükBütçe",
    "slug": "dusuk-butce",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dusukbutce.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Fiş fotoğrafı çekmek için kamera erişimi gereklidir.",
        "NSPhotoLibraryUsageDescription": "Galerinizden fiş seçmek için fotoğraf erişimi gereklidir.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.dusukbutce.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      [
        "expo-camera",
        { "cameraPermission": "Fiş fotoğrafı çekmek için kamera izni gereklidir." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "Galerinizden fiş seçmek için fotoğraf izni gereklidir." }
      ]
    ]
  }
}
